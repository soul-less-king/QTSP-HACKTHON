# ----------------------------------------------------------------------------
# Axis Event Management System — environment variables
# Copy this file to `.env.local` for local dev (gitignored), and set the same
# values in the Vercel dashboard for production.
# ----------------------------------------------------------------------------

# PostgreSQL connection string.
# Get a free serverless Postgres at https://neon.tech or use Vercel Postgres.
# Example: postgresql://user:password@ep-xxx.region.aws.neon.tech/axis?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/axis?sslmode=require"

# JWT signing secrets — generate with:  openssl rand -base64 48
JWT_SECRET_KEY="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET_KEY="change-me-to-another-long-random-string"

# OpenRouter API key for LLM booking extraction (https://openrouter.ai).
# Leave blank to use the built-in deterministic mock parser (demo works without it).
# Use a current OpenRouter slug. Older "anthropic/claude-3.5-sonnet" is retired.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-3.5-haiku"

# Public app URL (used for OpenRouter referer header)
QSTP_DOMAIN="https://qstp.qa"
